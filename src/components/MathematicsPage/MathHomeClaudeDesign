    <div class="spacer"></div>

    <button class="lang-switch">
      <span class="flag">EN</span>
      English
    </button>

    <div class="sidebar-stats">
      <div class="sb-stat">
        <svg class="sb-icon" viewBox="0 0 24 24" fill="#FFC800"><path d="M12 2.6 14.7 8.4l6.3.6-4.7 4.3 1.4 6.2L12 16.7l-5.7 2.8 1.4-6.2L3 9l6.3-.6L12 2.6Z"/></svg>
        <span><strong>7</strong> bintang</span>
      </div>
      <div class="sb-stat">
        <svg class="sb-icon" viewBox="0 0 24 24" fill="#FF4B4B"><path d="M12 20.3c-.4 0-.8-.15-1.1-.45L3.6 12.6A5 5 0 0 1 10.7 5.5l1.3 1.3 1.3-1.3A5 5 0 0 1 20.4 12.6l-7.3 7.25c-.3.3-.7.45-1.1.45Z"/></svg>
        <span><strong>3</strong> nyawa</span>
      </div>
      <div class="sb-stat">
        <svg class="sb-icon" viewBox="0 0 24 24" fill="#1CB0F6"><path d="M7.5 4h9l4 5-8.5 11L3.5 9l4-5Z"/></svg>
        <span><strong>81</strong> permata</span>
      </div>
    </div>
  </aside>

  <!-- ──────────── MAIN ──────────── -->
  <main class="main">

    <!-- ─── Top bar ─── -->
    <div class="topbar">
      <button class="iconbtn" aria-label="Back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 5 7.6 11.6a.5.5 0 0 0 0 .8L14.5 19"/></svg>
      </button>
