      <button class="nav-item">
        <span class="nav-icon-bg nav-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#4A90E2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8" fill="#4A90E2"/></svg>
        </span>
        <span>Profil</span>
      </button>
      <button class="nav-item">
        <span class="nav-icon-bg nav-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#FF7A00"><circle cx="12" cy="11" r="7"/><path d="M9 17l-1 5 4-3 4 3-1-5" fill="#FF7A00"/></svg>
        </span>
        <span>Pencapaian</span>
      </button>
