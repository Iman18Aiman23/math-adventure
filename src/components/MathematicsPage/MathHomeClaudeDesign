          <circle cx="43" cy="43" r="1" fill="#fff"/>
          <circle cx="59" cy="43" r="1" fill="#fff"/>
          <path d="M44 53c1.5 2 4 3 6 3s4.5-1 6-3" stroke="#1B1D29" stroke-width="2" fill="none" stroke-linecap="round"/>
          <path d="M22 80c0-12 12-18 28-18s28 6 28 18v8H22v-8Z" fill="#58CC02"/>
        </svg>
      </div>
      <div>
        <div class="brand-name">ImanCore</div>
        <div class="brand-tag">LEARNING HUB</div>
      </div>
    </div>

    <nav class="nav">
      <button class="nav-item active">
        <span class="nav-icon-bg nav-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M4 6c0-1 .8-2 2-2h6a3 3 0 0 1 3 3v13a2 2 0 0 0-2-2H6a2 2 0 0 1-2-2V6Z"/><path d="M20 6c0-1-.8-2-2-2h-6a3 3 0 0 0-3 3v13a2 2 0 0 1 2-2h6a2 2 0 0 0 2-2V6Z" opacity=".7"/></svg>
