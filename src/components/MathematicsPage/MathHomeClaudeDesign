<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>ImanCore · Matematik</title>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&family=Nunito:wght@600;700;800;900&display=swap" rel="stylesheet"/>
<style>
  :root{
    /* Brand */
    --primary:#4A90E2;
    --secondary:#9013FE;
    --surface:#FFFFFF;
    --text-main:#111827;

    --bg:#FFFDF8;
    --ink:#111827;
    --ink2:#374151;
    --muted:#6B7280;
    --hair:#E8E5DD;

    /* bezel */
    --bezel-1:#FFFFFF;
    --bezel-2:#F4EFE6;
    --bezel-3:#D9D0BD;

    /* Subjects */
    --c1-light:#FFF0CC; --c1-base:#FF9600; --c1-dark:#D47A00; --c1-deep:#8F5300;  /* Orange */
    --c2-light:#D0F0FF; --c2-base:#1CB0F6; --c2-dark:#0B8DC0; --c2-deep:#06628A;  /* Sky */
    --c3-light:#EDD9FF; --c3-base:#CE82FF; --c3-dark:#9B59B6; --c3-deep:#6E3B85;  /* Purple */
    --c4-light:#E6FFD4; --c4-base:#58CC02; --c4-dark:#46A302; --c4-deep:#2E6B00;  /* Green */

    /* Stats */
    --c-heart:#FF4B4B; --c-gem:#1CB0F6; --c-star:#FFC800; --c-flame:#FF7A00;
  }
  *{box-sizing:border-box}
  html,body{margin:0;background:var(--bg);color:var(--ink);font-family:'Nunito',system-ui,sans-serif;-webkit-font-smoothing:antialiased}

  /* ─── Layout ─── */
  .layout{
    display:grid;
    grid-template-columns:240px 1fr;
    min-height:100vh;
    max-width:1440px;
    margin:0 auto;
    gap:24px;
    padding:18px;
  }
  @media (max-width:900px){
    .layout{grid-template-columns:1fr;padding:12px;gap:14px}
    .sidebar{position:sticky;top:0;flex-direction:row !important;align-items:center;padding:10px 14px !important;gap:12px}
    .sidebar .nav{flex-direction:row !important;gap:6px !important;margin:0 !important;flex:1;overflow-x:auto}
    .sidebar .nav-item span:not(.nav-icon){display:none}
    .sidebar .brand{flex-direction:row !important;gap:10px;text-align:left !important;padding-bottom:0 !important;border:0 !important}
    .sidebar .mascot{margin:0 !important;width:42px !important;height:42px !important}
    .sidebar .brand-name{font-size:18px !important}
    .sidebar .brand-tag{display:none}
    .sidebar .lang-switch, .sidebar .sidebar-stats, .sidebar .spacer{display:none}
  }

  /* ─── Sidebar ─── */
  .sidebar{
    background:#fff;border-radius:24px;
    padding:22px 16px 20px;
    display:flex;flex-direction:column;gap:16px;
    box-shadow:0 0 0 1px var(--hair), 0 12px 24px -16px rgba(20,30,60,.08);
    height:fit-content;position:sticky;top:18px;
  }
  .brand{display:flex;flex-direction:column;align-items:center;gap:8px;text-align:center;padding:4px 0 14px;border-bottom:2px dashed var(--hair)}
  .mascot{
    width:72px;height:72px;border-radius:24px;
    background:linear-gradient(135deg, var(--primary), var(--secondary));
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 6px 0 rgba(74,7,132,.22), 0 12px 18px -8px rgba(144,19,254,.4);
  }
  .brand-name{font-family:'Baloo 2',sans-serif;font-weight:800;font-size:20px;letter-spacing:-0.02em;color:var(--ink);line-height:1}
  .brand-tag{font-family:'Baloo 2';font-weight:700;font-size:10px;letter-spacing:0.16em;color:var(--c-star);margin-top:2px}

  .nav{display:flex;flex-direction:column;gap:6px;margin-top:8px}
  .nav-item{
    display:flex;align-items:center;gap:12px;
    padding:11px 12px;border-radius:14px;border:0;cursor:pointer;
    background:transparent;color:var(--ink2);
    font-family:'Baloo 2',sans-serif;font-weight:700;font-size:15px;
    transition:transform .15s, background .15s;
    text-align:left;width:100%;
  }
  .nav-item:hover{background:#F5F7FB;transform:translateX(2px)}
  .nav-item.active{
    background:linear-gradient(135deg, var(--primary), var(--secondary));
    color:#fff;
    box-shadow:0 4px 0 rgba(74,7,132,.18), 0 8px 16px -6px rgba(144,19,254,.4);
  }
  .nav-item.active .nav-icon-bg{background:rgba(255,255,255,.18) !important}
  .nav-icon-bg{
    width:30px;height:30px;border-radius:10px;display:flex;align-items:center;justify-content:center;
    background:#F1F5FB;flex-shrink:0;
  }
  .nav-icon-bg svg{display:block}

  .sidebar .spacer{flex:1;min-height:8px}

  .lang-switch{
    display:flex;align-items:center;gap:10px;
    padding:9px 12px;border-radius:14px;
    background:#F5F7FB;border:0;cursor:pointer;
    font-family:'Baloo 2';font-weight:700;font-size:13px;color:var(--ink2);
  }
  .lang-switch:hover{background:#ECEFF6}
  .flag{
    width:24px;height:24px;border-radius:50%;
    background:linear-gradient(135deg,#3FB7F1,#CE82FF);display:flex;align-items:center;justify-content:center;
    font-size:12px;color:#fff;font-weight:800;
  }

  .sidebar-stats{display:flex;flex-direction:column;gap:8px;padding-top:14px;border-top:2px dashed var(--hair)}
  .sb-stat{display:flex;align-items:center;gap:10px;font-family:'Baloo 2';font-weight:700;font-size:13px;color:var(--ink2)}
  .sb-stat strong{color:var(--ink);margin-right:2px}
  .sb-icon{width:20px;height:20px;display:block}

  /* ─── Main ─── */
  .main{display:flex;flex-direction:column;gap:22px}

  /* ─── Top page header ─── */
  .topbar{
    display:flex;align-items:center;gap:12px;
    padding:4px 4px;
  }
  .iconbtn{
    width:42px;height:42px;border-radius:14px;border:0;cursor:pointer;
    background:#fff;color:var(--ink2);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 3px 0 var(--hair), 0 0 0 1px var(--hair);
    transition:transform .12s;
  }
  .iconbtn:hover{transform:translateY(-1px)}
  .topbar .spacer{flex:1}
  .stat{display:inline-flex;align-items:center;gap:6px;font-family:'Baloo 2';font-weight:800;font-size:14px;color:var(--ink);padding:6px 4px}
  .stat .label{color:var(--muted);font-weight:700}
  .stat .stat-num{color:var(--c)}
  .stat-sep{color:#D5CFC0;font-weight:800;margin:0 6px;font-size:18px;line-height:1}

  /* ─── Hero ─── */
  .hero{
    position:relative;overflow:hidden;
    border-radius:28px;
    background:linear-gradient(135deg, #4A90E2 0%, #6E5FE6 45%, #9013FE 100%);
    color:#fff;
    padding:30px 32px 30px;
    box-shadow:0 10px 30px -10px rgba(74,7,132,.45);
    isolation:isolate;
    text-align:center;
  }
  .hero::before{
    content:"";position:absolute;inset:0;z-index:-1;
    background:
      radial-gradient(2px 2px at 10% 20%, rgba(255,255,255,.7) 50%, transparent 51%),
      radial-gradient(2px 2px at 30% 60%, rgba(255,255,255,.6) 50%, transparent 51%),
      radial-gradient(1.5px 1.5px at 70% 30%, rgba(255,255,255,.7) 50%, transparent 51%),
      radial-gradient(2px 2px at 50% 80%, rgba(255,255,255,.5) 50%, transparent 51%),
      radial-gradient(1px 1px at 88% 50%, rgba(255,255,255,.55) 50%, transparent 51%),
      radial-gradient(2px 2px at 22% 88%, rgba(255,255,255,.55) 50%, transparent 51%),
      radial-gradient(1px 1px at 60% 12%, rgba(255,255,255,.8) 50%, transparent 51%);
  }

  /* floating math glyphs in hero */
  .math-glyph{
    position:absolute;font-family:'Baloo 2';font-weight:800;
    color:rgba(255,255,255,.18);user-select:none;pointer-events:none;
    animation:floaty 6s ease-in-out infinite;
  }
  @keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
  .g1{top:14px;left:6%;font-size:38px;animation-delay:0s}
  .g2{top:24px;right:8%;font-size:32px;animation-delay:1.2s}
  .g3{bottom:18px;left:12%;font-size:28px;animation-delay:2.4s}
  .g4{bottom:24px;right:14%;font-size:42px;animation-delay:1.8s}
  .g5{top:54%;left:3%;font-size:22px;animation-delay:.8s}
  .g6{top:46%;right:4%;font-size:26px;animation-delay:2.8s}

  .hero-icon{
    width:104px;height:104px;margin:0 auto 10px;display:block;
    animation:popper 3.6s ease-in-out infinite;
  }
  @keyframes popper{0%,100%{transform:translateY(0) rotate(-3deg)}50%{transform:translateY(-6px) rotate(3deg)}}

  .hero-title{
    font-family:'Baloo 2',sans-serif;font-weight:800;font-size:40px;letter-spacing:-0.02em;line-height:1.1;
    text-shadow:0 2px 0 rgba(0,0,0,.14);margin:0 0 8px;
  }
  .hero-sub{
    font-family:'Nunito';font-weight:700;font-size:14px;color:rgba(255,255,255,.92);
    max-width:520px;margin:0 auto;line-height:1.5;
  }

  /* ─── Section label ─── */
  .section-label{
    font-family:'Baloo 2';font-weight:800;font-size:13px;letter-spacing:0.16em;
    color:var(--muted);margin:6px 4px 0;
  }

  /* ─── Topic cards (tile style — matches Reading) ─── */
  .topics{
    display:grid;
    grid-template-columns:repeat(3,1fr);gap:26px;
  }
  @media (max-width:1100px){.topics{grid-template-columns:repeat(2,1fr)}}
  @media (max-width:680px){.topics{grid-template-columns:1fr;gap:20px}}

  .topic{
    --bg:var(--c4-light); --base:var(--c4-base); --dark:var(--c4-dark); --deep:var(--c4-deep);
    position:relative;
    border:0;cursor:pointer;padding:0;
    width:100%;aspect-ratio:1/1.18;
    border-radius:30px;
    font-family:inherit;
    background:linear-gradient(180deg, var(--bg) 0%, color-mix(in srgb, var(--base) 60%, white) 55%, var(--base) 100%);
    box-shadow:
      0 0 0 5px var(--bezel-1),
      0 0 0 8px var(--bezel-2),
      0 0 0 9px var(--bezel-3),
      0 12px 0 -2px var(--deep),
      0 22px 28px -10px rgba(0,0,0,.22);
    overflow:hidden;
    transition:transform .18s cubic-bezier(.34,1.56,.64,1), box-shadow .18s ease;
    text-align:left;color:#fff;
  }
  .topic:hover{
    transform:translateY(-4px) rotate(-1deg);
    box-shadow:
      0 0 0 5px var(--bezel-1),
      0 0 0 8px var(--bezel-2),
      0 0 0 9px var(--bezel-3),
      0 16px 0 -2px var(--deep),
      0 30px 38px -10px rgba(0,0,0,.28);
  }
  .topic:active{
    transform:translateY(8px);
    box-shadow:
      0 0 0 5px var(--bezel-1),
      0 0 0 8px var(--bezel-2),
      0 0 0 9px var(--bezel-3),
      0 4px 0 -2px var(--deep),
      0 10px 14px -8px rgba(0,0,0,.22);
  }
  .topic.t1{--bg:var(--c4-light); --base:var(--c4-base); --dark:var(--c4-dark); --deep:var(--c4-deep)} /* green */
  .topic.t2{--bg:var(--c1-light); --base:var(--c1-base); --dark:var(--c1-dark); --deep:var(--c1-deep)} /* orange */
  .topic.t3{--bg:var(--c2-light); --base:var(--c2-base); --dark:var(--c2-dark); --deep:var(--c2-deep)} /* sky */

  /* top gloss */
  .topic::before{
    content:"";position:absolute;
    top:8px;left:18px;right:18px;height:38%;border-radius:28px 28px 80% 80%;
    background:linear-gradient(180deg, rgba(255,255,255,.6) 0%, rgba(255,255,255,.12) 70%, transparent 100%);
    pointer-events:none;z-index:1;
  }
  /* dot texture */
  .topic::after{
    content:"";position:absolute;inset:0;
    background-image:radial-gradient(rgba(255,255,255,.16) 1.5px, transparent 1.6px);
    background-size:18px 18px;
    background-position:0 0;
    opacity:.6;pointer-events:none;
  }

  /* corner spinning star */
  .badge-corner{
    position:absolute;top:12px;right:12px;z-index:3;
    animation:spin 8s linear infinite;
    opacity:.95;
  }
  @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

  /* Tag chip top-left */
  .topic-tag-floating{
    position:absolute;top:14px;left:14px;z-index:3;
    display:inline-flex;align-items:center;gap:5px;
    padding:6px 10px 6px 8px;border-radius:999px;
    background:#fff;color:var(--deep);
    font-family:'Baloo 2';font-weight:800;font-size:11px;letter-spacing:0.1em;
    box-shadow:0 3px 0 rgba(0,0,0,.14);
    transition:transform .3s;
  }
  .topic:hover .topic-tag-floating{transform:rotate(-6deg) scale(1.06)}

  /* sparkles on hover */
  .spark{position:absolute;z-index:3;opacity:0;transition:opacity .3s, transform .5s}
  .topic:hover .spark{opacity:1}
  .topic:hover .spark.s1{transform:translate(-6px,-8px) scale(1.2) rotate(20deg)}
  .topic:hover .spark.s2{transform:translate(6px,-6px) scale(1.15) rotate(-15deg)}
  .topic:hover .spark.s3{transform:translate(-4px,6px) scale(1.1) rotate(10deg)}

  /* Illustration zone */
  .topic-illo{
    position:absolute;top:48px;left:0;right:0;bottom:130px;
    display:flex;align-items:center;justify-content:center;
    z-index:2;
  }
  .topic-illo svg{width:80%;height:auto;max-height:100%;filter:drop-shadow(0 8px 6px rgba(0,0,0,.2));transition:transform .4s cubic-bezier(.34,1.56,.64,1)}
  .topic:hover .topic-illo svg{transform:scale(1.08) translateY(-4px) rotate(-3deg)}

  /* Bottom plate */
  .topic-plate{
    position:absolute;bottom:14px;left:14px;right:14px;
    background:#fff;border-radius:22px;
    padding:14px 16px 12px;
    box-shadow:0 4px 0 rgba(0,0,0,.08);
    z-index:3;
  }
  .topic-plate .title{
    font-family:'Baloo 2',sans-serif;font-weight:800;font-size:20px;color:var(--ink);
    line-height:1.05;letter-spacing:-0.01em;
  }
  .topic-plate .desc{
    margin-top:4px;
    font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;color:var(--muted);
    line-height:1.35;
    overflow:hidden;text-overflow:ellipsis;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;
  }
  .topic-plate .desc b{color:var(--dark)}
  .topic-plate .row{
    display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:10px;
  }
  .topic-progress{
    flex:1;min-width:0;
  }
  .topic-progress .meta{
    display:flex;justify-content:space-between;align-items:baseline;
    font-family:'Baloo 2';font-weight:800;font-size:11px;color:var(--muted);letter-spacing:0.04em;margin-bottom:4px;
  }
  .topic-progress .meta strong{color:var(--dark);font-size:13px}
  .topic-progress .bar{height:6px;border-radius:999px;background:#F2EDE0;overflow:hidden}
  .topic-progress .bar i{display:block;height:100%;border-radius:999px;background:var(--base)}

  .topic-go{
    width:42px;height:42px;border-radius:50%;flex-shrink:0;
    background:radial-gradient(circle at 50% 30%, var(--bg) 0%, var(--base) 55%, var(--dark) 100%);
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 3px 0 var(--deep), 0 0 0 2px rgba(255,255,255,.8), 0 6px 10px -4px rgba(0,0,0,.25);
    position:relative;
  }
  .topic-go::before{content:"";position:absolute;top:4px;left:8px;right:8px;height:12px;border-radius:50%;background:radial-gradient(ellipse at 50% 0%, rgba(255,255,255,.9), transparent 70%)}
  .topic-go svg{position:relative;z-index:2;filter:drop-shadow(0 1px 0 var(--deep))}

  @media (max-width:680px){
    .topic-plate{padding:12px 14px 10px;border-radius:18px}
    .topic-plate .title{font-size:18px}
    .topic-plate .desc{font-size:11px}
    .topic-illo{top:54px;bottom:118px}
    .topic-go{width:36px;height:36px}
  }

  /* ─── Footer hint ─── */
  .hint{
    margin:4px 4px 0;
    font-family:'Nunito';font-size:12px;color:var(--muted);text-align:center;
    display:flex;align-items:center;justify-content:center;gap:8px;
  }
  .hint svg{flex-shrink:0}
</style>
</head>
<body>

<div class="layout">

  <!-- ──────────── SIDEBAR ──────────── -->
  <aside class="sidebar">
    <div class="brand">
      <div class="mascot">
        <svg width="50" height="50" viewBox="0 0 100 100" aria-hidden="true">
          <ellipse cx="50" cy="44" rx="22" ry="22" fill="#FFE0B8"/>
          <path d="M28 38c0-12 10-22 22-22s22 10 22 22c0 4-2 6-4 6-2-3-6-5-10-5-6 0-8 3-8 6 0-3-2-6-8-6-4 0-8 2-10 5-2 0-4-2-4-6Z" fill="#1B1D29"/>
          <circle cx="38" cy="50" r="3" fill="#FF9DA8" opacity=".75"/>
          <circle cx="62" cy="50" r="3" fill="#FF9DA8" opacity=".75"/>
          <ellipse cx="42" cy="44" rx="2.6" ry="3.4" fill="#1B1D29"/>
