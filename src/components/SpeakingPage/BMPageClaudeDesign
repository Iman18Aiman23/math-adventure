<script>
  document.querySelectorAll('.tile').forEach(tile => {
    tile.addEventListener('click', (e) => {
      const mode = tile.dataset.mode;
      tile.animate(
        [
          { transform: 'translateY(0) scale(1)' },
          { transform: 'translateY(-4px) scale(1.06)' },
          { transform: 'translateY(0) scale(1)' }
        ],
        { duration: 380, easing: 'cubic-bezier(.34,1.56,.64,1)' }
      );
      const rect = tile.getBoundingClientRect();
      const ripple = document.createElement('span');
      ripple.style.cssText = `
        position:absolute;left:${e.clientX - rect.left - 10}px;top:${e.clientY - rect.top - 10}px;
        width:20px;height:20px;border-radius:50%;
        background:radial-gradient(circle, rgba(255,255,255,.85) 0%, transparent 70%);
        pointer-events:none;z-index:6;
      `;
      tile.appendChild(ripple);
      ripple.animate(
        [{ transform: 'scale(1)', opacity: .85 }, { transform: 'scale(30)', opacity: 0 }],
        { duration: 700, easing: 'ease-out' }
      ).onfinish = () => ripple.remove();
      console.log('handleCategory:', mode);
    });
  });
</script>
