      Sebut &amp; Main! Bercakap untuk bermain.
      <span aria-hidden="true"><svg width="22" height="22" viewBox="0 0 24 24" fill="#1CB0F6"><path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3Zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.9V21h2v-3.1A7 7 0 0 0 19 11h-2Z"/></svg></span>
    </p>
  </section>

  <div class="section-label">Pilih Kategori</div>

  <div class="grid">

    <!-- 1. SUKU KATA KV (Sky) — Colorful KV syllable blocks -->
    <button class="tile t-kv" data-mode="bm_kv">
      <span class="tile-num">1</span>
      <span class="tile-mic" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3Zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.9V21h2v-3.1A7 7 0 0 0 19 11h-2Z"/></svg>
      </span>

      <span class="spark s1" style="top:24%;left:14%"><svg width="22" height="22" viewBox="0 0 24 24" fill="#fff"><path d="M12 2l2 7 7 2-7 2-2 7-2-7-7-2 7-2z"/></svg></span>
      <span class="spark s2" style="top:30%;right:14%"><svg width="16" height="16" viewBox="0 0 24 24" fill="#fff"><circle cx="12" cy="12" r="10"/></svg></span>

      <div class="illo">
        <svg viewBox="0 0 200 160">
          <ellipse cx="100" cy="150" rx="76" ry="7" fill="rgba(0,0,0,.22)"/>
