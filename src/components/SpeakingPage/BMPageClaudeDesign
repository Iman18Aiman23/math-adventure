              <text x="34" y="46" text-anchor="middle" font-family="'Fredoka',sans-serif" font-weight="700" font-size="32" fill="#fff">bu</text>
            </g>
          </g>
        </svg>
      </div>

      <div class="cap">
        <span class="cap-title">Suku Kata KV<small>ba · bi · bu · be · bo</small></span>
        <span class="cap-go" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </span>
      </div>
    </button>

    <!-- 2. SUKU KATA KVK (Purple) — closed syllable blocks -->
    <button class="tile t-kvk" data-mode="bm_kvk">
      <span class="tile-num">2</span>
      <span class="tile-mic" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 14a3 3 0 0 0 3-3V6a3 3 0 0 0-6 0v5a3 3 0 0 0 3 3Zm5-3a5 5 0 0 1-10 0H5a7 7 0 0 0 6 6.9V21h2v-3.1A7 7 0 0 0 19 11h-2Z"/></svg>
      </span>

      <span class="spark s1" style="top:24%;left:14%"><svg width="20" height="20" viewBox="0 0 24 24" fill="#fff"><path d="M12 2l2 7 7 2-7 2-2 7-2-7-7-2 7-2z"/></svg></span>
      <span class="spark s2" style="top:30%;right:14%"><svg width="14" height="14" viewBox="0 0 24 24" fill="#F1E2FF"><circle cx="12" cy="12" r="10"/></svg></span>

      <div class="illo">
        <svg viewBox="0 0 200 160">
          <ellipse cx="100" cy="150" rx="76" ry="7" fill="rgba(0,0,0,.22)"/>
          <g class="wobble">
            <!-- pill-shaped KVK chunk "ban" -->
